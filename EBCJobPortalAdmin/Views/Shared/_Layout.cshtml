@{
    var pageTitle = string.IsNullOrWhiteSpace(ViewData["Title"] as string)
        ? "EBC Admin"
        : $"{ViewData["Title"]} | EBC Admin";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var userName = User.FindFirst("UserName")?.Value ?? User.Identity?.Name ?? "Administrator";
    var displayName = User.FindFirst("FullName")?.Value ?? userName;
    var emailAddress = User.FindFirst("Email")?.Value ?? string.Empty;

    string NavClass(string controller, string action = "Index")
    {
        var isActive = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return isActive
            ? "admin-gradient text-white shadow-lg"
            : "text-slate-600 hover:bg-slate-100 hover:text-slate-950";
    }
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <meta name="theme-color" content="#023f5b" />
    <link rel="icon" type="image/png" href="~/assets/images/rounded_logo-removebg-preview.png" />

    @* Inter keeps the admin side aligned with the requested typography direction. *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    @* Tailwind via CDN keeps the admin UI easy to iterate on during Hot Reload sessions. *@
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        // The Tailwind config mirrors the client-side brand color so both portals feel like one system.
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            DEFAULT: "#023f5b",
                            light: "#0a5f84",
                            ink: "#012d41"
                        }
                    },
                    fontFamily: {
                        sans: ["Inter", "system-ui", "sans-serif"]
                    },
                    boxShadow: {
                        soft: "0 24px 60px rgba(2, 63, 91, 0.12)"
                    }
                }
            }
        };
    </script>

    <link rel="stylesheet" href="~/css/admin-portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tw-fallback.css" asp-append-version="true" />
</head>
<body class="admin-body min-h-screen antialiased">
    <div class="admin-app-shell flex min-h-screen">
        @* A light sidebar with strong icon contrast keeps navigation clear without feeling heavy. *@
        <aside class="hidden w-72 border-r border-slate-200/80 bg-white/80 backdrop-blur-xl lg:flex lg:flex-col">
            <div class="border-b border-slate-200/80 px-6 py-6">
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-4">
                    <img src="~/assets/images/rounded_logo-removebg-preview.png" alt="EBC" class="h-12 w-12 rounded-2xl border border-slate-200 bg-white p-1 shadow-sm" />
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">EBC Admin</p>
                        <h1 class="text-lg font-bold tracking-tight text-slate-950">Job Portal Dashboard</h1>
                    </div>
                </a>
            </div>

            <div class="flex-1 px-4 py-6">
                <div class="mb-6">
                    @* The gradient action button gives the sidebar a clear primary command. *@
                    <a asp-controller="JobLists" asp-action="Create" class="admin-gradient flex w-full items-center justify-center rounded-2xl px-4 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
                        Post New Job
                    </a>
                </div>

                <nav class="space-y-2">
                    <a asp-controller="Home" asp-action="Index" class="@NavClass("Home") admin-sidebar-link flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12 12 4l9 8" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 10v10h14V10" />
                            </svg>
                        </span>
                        Dashboard
                    </a>
                    <a asp-controller="JobLists" asp-action="Index" class="@NavClass("JobLists") admin-sidebar-link flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" />
                            </svg>
                        </span>
                        Job Management
                    </a>
                    <a asp-controller="Applicants" asp-action="Index" class="@NavClass("Applicants") admin-sidebar-link flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </span>
                        Applicants
                    </a>
                    <a asp-controller="AdminlUsers" asp-action="Index" class="@NavClass("AdminlUsers") admin-sidebar-link flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 20a8 8 0 0 1 16 0" />
                            </svg>
                        </span>
                        Admin Users
                    </a>
                    <a asp-controller="Regions" asp-action="Index" class="@NavClass("Regions") admin-sidebar-link flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-semibold">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-black/5">
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z" />
                                <circle cx="12" cy="11" r="2" />
                            </svg>
                        </span>
                        Regions
                    </a>
                </nav>
            </div>
        </aside>

        <div class="admin-main-column flex min-h-screen flex-1 flex-col">
            @* The top bar keeps identity and logout visible while letting the content area stay uncluttered. *@
            <header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/80 backdrop-blur-xl">
                <div class="mx-auto flex max-w-none items-center justify-between px-5 py-4 sm:px-8">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.06em] text-brand">Admin Workspace</p>
                        <h2 class="mt-1 text-xl font-bold tracking-tight text-slate-950">@pageTitle.Replace(" | EBC Admin", string.Empty)</h2>
                    </div>

                    <div class="flex items-center gap-4">
                        <div class="hidden text-right sm:block">
                            <p class="text-sm font-semibold text-slate-900">@userName</p>
                            <p class="text-xs text-slate-500">@(string.IsNullOrWhiteSpace(emailAddress) ? displayName : emailAddress)</p>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                                Logout
                            </button>
                        </form>
                    </div>
                </div>
            </header>

            <main class="flex-1 px-5 py-8 sm:px-8">
                <div class="admin-main-content">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    @await Component.InvokeAsync("NToastNotify")
    @await Component.InvokeAsync("Notyf")
</body>
</html>
