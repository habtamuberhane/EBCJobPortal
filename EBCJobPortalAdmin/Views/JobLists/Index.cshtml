@model IEnumerable<EBCJobPortalAdmin.Models.TblJobList>

@{
    ViewData["Title"] = "Job Management";
}

@* The jobs page uses a simple table layout so administrators can scan and act quickly. *@
<section class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-3">
            <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Vacancies</p>
            <h1 class="text-4xl font-bold tracking-tight text-slate-950">Job management</h1>
            <p class="text-base leading-7 text-slate-600">Create, review, edit, and remove published vacancies from one clean workspace.</p>
        </div>

        @* The gradient CTA is the main action on this page and matches the sidebar brand treatment. *@
        <a asp-action="Create" class="admin-gradient inline-flex items-center justify-center rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
            Post New Job
        </a>
    </div>

    <div class="admin-card overflow-hidden rounded-[2rem]">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50/80">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Title</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Posted</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Deadline</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                    @foreach (var item in Model)
                    {
                        var jobDescription = item.JobDescription ?? string.Empty;
                        var previewDescription = jobDescription.Length > 160
                            ? $"{jobDescription.Substring(0, 160)}..."
                            : jobDescription;

                        <tr class="transition hover:bg-slate-50/80">
                            <td class="px-6 py-5 align-top">
                                <div class="space-y-2">
                                    <p class="text-sm font-semibold text-slate-950">@item.JobTitle</p>
                                    <p class="max-w-xl text-sm leading-7 text-slate-600">@Html.Raw(previewDescription)</p>
                                </div>
                            </td>
                            <td class="px-6 py-5 align-top text-sm font-medium text-slate-700">@((item.PostedDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</td>
                            <td class="px-6 py-5 align-top text-sm font-medium text-slate-700">@((item.ExpiredDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</td>
                            <td class="px-6 py-5 align-top">
                                <div class="flex flex-wrap gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.JobId" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.JobId" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">View</a>
                                    <a asp-action="Delete" asp-route-id="@item.JobId" class="rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
