@model EBCJobPortalAdmin.ViewModel.JobModel

@{
    ViewData["Title"] = "Create Job";
}

<section class="space-y-8">
    <div class="max-w-3xl space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Job Management</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Post new vacancy</h1>
        <p class="text-base leading-7 text-slate-600">Publish a new job opening with clear title, description, and deadline details.</p>
    </div>

    <div class="admin-card max-w-4xl rounded-[2rem] p-8">
        <form asp-action="Create" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div class="space-y-2">
                <label asp-for="JobTitle" class="text-sm font-semibold text-slate-700">Position title</label>
                <input asp-for="JobTitle" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                <span asp-validation-for="JobTitle" class="text-sm text-red-600"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="JobDescription" class="text-sm font-semibold text-slate-700">Job description</label>
                <textarea asp-for="JobDescription" rows="10" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm leading-7 text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10"></textarea>
                <span asp-validation-for="JobDescription" class="text-sm text-red-600"></span>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
                <div class="space-y-2">
                    <label asp-for="PostedDate" class="text-sm font-semibold text-slate-700">Posted date</label>
                    <input asp-for="PostedDate" type="datetime-local" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                    <span asp-validation-for="PostedDate" class="text-sm text-red-600"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="ExpiredDate" class="text-sm font-semibold text-slate-700">Deadline</label>
                    <input asp-for="ExpiredDate" type="datetime-local" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                    <span asp-validation-for="ExpiredDate" class="text-sm text-red-600"></span>
                </div>
            </div>

            <div class="space-y-2">
                <label asp-for="RequiredNumber" class="text-sm font-semibold text-slate-700">Required positions</label>
                <input asp-for="RequiredNumber" type="number" min="1" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                <span asp-validation-for="RequiredNumber" class="text-sm text-red-600"></span>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="admin-gradient rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
                    Create job
                </button>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
