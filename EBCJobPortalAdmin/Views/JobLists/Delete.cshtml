@model EBCJobPortalAdmin.Models.TblJobList

@{
    ViewData["Title"] = "Delete Job";
}

<section class="space-y-8">
    <div class="max-w-3xl space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Job Management</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Delete vacancy</h1>
        <p class="text-base leading-7 text-slate-600">Review the vacancy details before permanently removing it from the portal.</p>
    </div>

    <div class="admin-card max-w-4xl rounded-[2rem] p-8">
        <div class="space-y-6">
            <div class="rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm leading-7 text-red-700">
                This action will permanently remove this vacancy from the admin dashboard.
            </div>

            <dl class="grid gap-5 md:grid-cols-2">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                    <dt class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Title</dt>
                    <dd class="mt-2 text-sm font-semibold text-slate-900">@Model.JobTitle</dd>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                    <dt class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Posted</dt>
                    <dd class="mt-2 text-sm font-semibold text-slate-900">@((Model.PostedDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</dd>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                    <dt class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Deadline</dt>
                    <dd class="mt-2 text-sm font-semibold text-slate-900">@((Model.ExpiredDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</dd>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 md:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Description</dt>
                    <dd class="mt-2 text-sm leading-7 text-slate-600">@Html.Raw(Model.JobDescription)</dd>
                </div>
            </dl>

            <form asp-action="Delete" class="flex flex-wrap gap-3 pt-2">
                <input type="hidden" asp-for="JobId" />
                <button type="submit" class="rounded-2xl bg-red-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-red-700">
                    Delete job
                </button>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</section>
