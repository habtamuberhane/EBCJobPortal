@model EBCJobPortalAdmin.Models.TblJobList

@{
    ViewData["Title"] = "Job Details";
}

<section class="space-y-8">
    <div class="max-w-3xl space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Job Management</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Vacancy details</h1>
        <p class="text-base leading-7 text-slate-600">Review the vacancy content exactly as it is stored in the portal.</p>
    </div>

    <div class="admin-card max-w-5xl rounded-[2rem] p-8">
        <div class="grid gap-5 md:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Title</p>
                <p class="mt-2 text-sm font-semibold text-slate-900">@Model.JobTitle</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Posted</p>
                <p class="mt-2 text-sm font-semibold text-slate-900">@((Model.PostedDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                <p class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Deadline</p>
                <p class="mt-2 text-sm font-semibold text-slate-900">@((Model.ExpiredDate ?? DateTime.Now).ToString("MMM dd, yyyy"))</p>
            </div>
        </div>

        <div class="mt-6 rounded-[1.75rem] border border-slate-200 bg-white px-6 py-6">
            <p class="text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Description</p>
            <div class="mt-4 text-sm leading-7 text-slate-700">
                @Html.Raw(Model.JobDescription)
            </div>
        </div>

        <div class="flex flex-wrap gap-3 pt-8">
            <a asp-action="Edit" asp-route-id="@Model.JobId" class="admin-gradient rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
                Edit vacancy
            </a>
            <a asp-action="Index" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                Back to jobs
            </a>
        </div>
    </div>
</section>
