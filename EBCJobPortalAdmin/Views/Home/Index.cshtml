@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

@* The dashboard opens with a quiet summary grid so administrators can understand portal activity immediately. *@
<section class="space-y-8">
    <div class="max-w-3xl space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Overview</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Recruitment dashboard</h1>
        <p class="text-base leading-7 text-slate-600">A focused summary of jobs, applications, and currently active vacancies.</p>
    </div>

    @if (!Model.IsDatabaseAvailable)
    {
        @* A warning banner keeps the admin shell usable even when SQL Server is offline. *@
        <div class="rounded-[1.75rem] border border-amber-200 bg-amber-50 px-6 py-5 text-amber-800">
            <p class="text-sm font-semibold uppercase tracking-[0.06em]">Database unavailable</p>
            <p class="mt-2 text-sm leading-7">@Model.StatusMessage</p>
        </div>
    }

    @* Three cards are enough to create a clear dashboard without recreating the clutter of the legacy template. *@
    <div class="grid gap-6 xl:grid-cols-3">
        <a asp-controller="JobLists" asp-action="Index" class="admin-card block rounded-[2rem] p-6 transition duration-300 hover:-translate-y-0.5">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Total Jobs</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.TotalJobs</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">All job records currently stored in the portal.</p>
        </a>

        <a asp-controller="Applicants" asp-action="Index" class="admin-card block rounded-[2rem] p-6 transition duration-300 hover:-translate-y-0.5">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Total Applicants</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.TotalApplicants</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Submitted applications available for HR review.</p>
        </a>

        <a asp-controller="JobLists" asp-action="Index" class="admin-card block rounded-[2rem] p-6 transition duration-300 hover:-translate-y-0.5">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Active Vacancies</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.ActiveVacancies</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Open opportunities currently visible to applicants.</p>
        </a>
    </div>
</section>
