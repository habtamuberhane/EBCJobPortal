@model IEnumerable<EBCJobPortalAdmin.Models.TblRegion>

@{
    ViewData["Title"] = "Regions";
}

<section class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-3">
            <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Locations</p>
            <h1 class="text-4xl font-bold tracking-tight text-slate-950">Regions</h1>
            <p class="text-base leading-7 text-slate-600">Manage the regional values used across job postings and applicant records.</p>
        </div>

        <a asp-action="Create" class="admin-gradient inline-flex items-center justify-center rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
            Add Region
        </a>
    </div>

    <div class="admin-card overflow-hidden rounded-[2rem]">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50/80">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Region Name</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                    @foreach (var item in Model)
                    {
                        <tr class="transition hover:bg-slate-50/80">
                            <td class="px-6 py-5 text-sm font-semibold text-slate-950">@item.RegionName</td>
                            <td class="px-6 py-5">
                                <div class="flex flex-wrap gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Regid" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Regid" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">View</a>
                                    <a asp-action="Delete" asp-route-id="@item.Regid" class="rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
