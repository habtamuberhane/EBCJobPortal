@model EBCJobPortalAdmin.Models.TblRegion

@{
    ViewData["Title"] = "Edit Region";
}

<section class="space-y-8">
    <div class="max-w-3xl space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Locations</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Edit region</h1>
        <p class="text-base leading-7 text-slate-600">Update the region label used across applications and vacancies.</p>
    </div>

    <div class="admin-card max-w-3xl rounded-[2rem] p-8">
        <form asp-action="Edit" class="space-y-6">
            <input type="hidden" asp-for="Regid" />
            <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

            <div class="space-y-2">
                <label asp-for="RegionName" class="text-sm font-semibold text-slate-700"></label>
                <input asp-for="RegionName" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                <span asp-validation-for="RegionName" class="text-sm text-red-600"></span>
            </div>

            <div class="flex flex-wrap gap-3 pt-2">
                <button type="submit" class="admin-gradient rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
                    Save changes
                </button>
                <a asp-action="Index" class="rounded-2xl border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
