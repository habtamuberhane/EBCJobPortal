@model EBCJobPortalAdmin.Models.TblApplicant

@{
    ViewData["Title"] = "Delete Applicant";
}

<section class="max-w-3xl space-y-6">
    <div class="space-y-3">
        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Applicant Record</p>
        <h1 class="text-4xl font-bold tracking-tight text-slate-950">Delete Applicant</h1>
        <p class="text-base leading-7 text-slate-600">This action permanently removes the selected application from the recruitment pipeline.</p>
    </div>

    <div class="admin-card rounded-[2rem] border border-red-100 p-6">
        <div class="space-y-4">
            <div>
                <p class="text-sm font-semibold text-slate-500">Applicant</p>
                <p class="mt-1 text-lg font-semibold text-slate-950">@Model.FullName</p>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <p class="text-sm font-semibold text-slate-500">Vacancy</p>
                    <p class="mt-1 text-sm text-slate-900">@(Model.Job?.JobTitle ?? "Not provided")</p>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-500">Submitted</p>
                    <p class="mt-1 text-sm text-slate-900">@(Model.RegistrationDate?.ToString("MMM dd, yyyy") ?? "Not provided")</p>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-500">Contact</p>
                    <p class="mt-1 text-sm text-slate-900">@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? "Not provided" : Model.PhoneNumber)</p>
                </div>
                <div>
                    <p class="text-sm font-semibold text-slate-500">Experience</p>
                    <p class="mt-1 text-sm text-slate-900">@(Model.NumberofExprianceYears?.ToString() ?? "0") years</p>
                </div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-8 flex flex-wrap gap-3">
            <input type="hidden" asp-for="ApplyId" />
            <button type="submit" class="inline-flex items-center justify-center rounded-2xl bg-red-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-red-700">
                Permanently Delete
            </button>
            <a asp-action="Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                Cancel
            </a>
        </form>
    </div>
</section>
