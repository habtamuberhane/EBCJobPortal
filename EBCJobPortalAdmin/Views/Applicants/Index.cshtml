@model EBCJobPortalAdmin.ViewModel.ApplicantsListModel
@using System.Globalization
@{
    ViewData["Title"] = "Applicants";

    var applicants = Model.Applicants ?? new List<TblApplicant>();
    var previousPage = Model.PageNumber - 1;
    var nextPage = Model.PageNumber + 1;
}

@functions {
    private IDictionary<string, string> BuildRouteValues(ApplicantsListModel model, int pageNumber)
    {
        var routeValues = new Dictionary<string, string>
        {
            ["PageNumber"] = pageNumber.ToString(CultureInfo.InvariantCulture)
        };

        if (model.JobId.HasValue)
        {
            routeValues["JobId"] = model.JobId.Value.ToString(CultureInfo.InvariantCulture);
        }

        if (model.Regid.HasValue)
        {
            routeValues["Regid"] = model.Regid.Value.ToString(CultureInfo.InvariantCulture);
        }

        if (!string.IsNullOrWhiteSpace(model.Gender))
        {
            routeValues["Gender"] = model.Gender;
        }

        if (!string.IsNullOrWhiteSpace(model.DisabilityStatus))
        {
            routeValues["DisabilityStatus"] = model.DisabilityStatus;
        }

        if (!string.IsNullOrWhiteSpace(model.EducationLevel))
        {
            routeValues["EducationLevel"] = model.EducationLevel;
        }

        if (model.MinimumCgpa.HasValue)
        {
            routeValues["MinimumCgpa"] = model.MinimumCgpa.Value.ToString(CultureInfo.InvariantCulture);
        }

        if (model.MinimumExperienceYears.HasValue)
        {
            routeValues["MinimumExperienceYears"] = model.MinimumExperienceYears.Value.ToString(CultureInfo.InvariantCulture);
        }

        return routeValues;
    }
}

<section class="space-y-8">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl space-y-3">
            <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Recruitment Pipeline</p>
            <h1 class="text-4xl font-bold tracking-tight text-slate-950">Applicants</h1>
            <p class="text-base leading-7 text-slate-600">Review submissions with shortlist-ready filters, then open each application in a cleaner HR-friendly detail view.</p>
        </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-5">
        <div class="admin-card rounded-[2rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Total Applicants</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.TotalApplicants</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">All submissions currently available for review.</p>
        </div>
        <div class="admin-card rounded-[2rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Vacancies Covered</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.TotalVacanciesCovered</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Distinct roles that have received applications.</p>
        </div>
        <div class="admin-card rounded-[2rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Disability Disclosed</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.TotalDisabilityDisclosed</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Applicants who indicated a disability on the form.</p>
        </div>
        <div class="admin-card rounded-[2rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Avg Experience</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.AverageExperience</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Average years of experience across current submissions.</p>
        </div>
        <div class="admin-card rounded-[2rem] p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.06em] text-slate-500">Avg CGPA</p>
            <p class="mt-4 text-4xl font-bold tracking-tight text-slate-950">@Model.AverageCgpa</p>
            <p class="mt-3 text-sm leading-7 text-slate-600">Academic grade average for applicants who submitted a CGPA.</p>
        </div>
    </div>

    <form asp-action="Index" method="post" class="admin-card rounded-[2rem] p-6">
        @Html.AntiForgeryToken()
        <div class="admin-filter-grid">
            <div class="space-y-2">
                <label asp-for="JobId" class="text-sm font-semibold text-slate-700">Vacancy</label>
                @Html.DropDownListFor(model => model.JobId, new SelectList(Model.Jobs, "Value", "Text", Model.JobId), "All vacancies", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
            </div>
            <div class="space-y-2">
                <label asp-for="Regid" class="text-sm font-semibold text-slate-700">Region</label>
                @Html.DropDownListFor(model => model.Regid, new SelectList(Model.Regions, "Value", "Text", Model.Regid), "All regions", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
            </div>
            <div class="space-y-2">
                <label asp-for="Gender" class="text-sm font-semibold text-slate-700">Gender</label>
                @Html.DropDownListFor(model => model.Gender, new SelectList(Model.Genders, "Value", "Text", Model.Gender), "All genders", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
            </div>
            <div class="space-y-2">
                <label asp-for="DisabilityStatus" class="text-sm font-semibold text-slate-700">Disability</label>
                @Html.DropDownListFor(model => model.DisabilityStatus, new SelectList(Model.DisabilityStatuses, "Value", "Text", Model.DisabilityStatus), "All applicants", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
            </div>
            <div class="space-y-2">
                <label asp-for="EducationLevel" class="text-sm font-semibold text-slate-700">Education level</label>
                @Html.DropDownListFor(model => model.EducationLevel, new SelectList(Model.EducationLevels, "Value", "Text", Model.EducationLevel), "All levels", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
            </div>
            <div class="space-y-2">
                <label asp-for="MinimumCgpa" class="text-sm font-semibold text-slate-700">Minimum CGPA</label>
                <input asp-for="MinimumCgpa" type="number" step="0.01" min="0" max="4" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" placeholder="e.g. 3.00" />
            </div>
            <div class="space-y-2">
                <label asp-for="MinimumExperienceYears" class="text-sm font-semibold text-slate-700">Minimum experience</label>
                <input asp-for="MinimumExperienceYears" type="number" step="0.5" min="0" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" placeholder="e.g. 2" />
            </div>
            <div class="flex items-end gap-3">
                <button type="submit" class="admin-gradient inline-flex min-h-[3rem] items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5">
                    Apply Filters
                </button>
                <a asp-action="Index" class="inline-flex min-h-[3rem] items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Reset
                </a>
            </div>
        </div>
    </form>

    <div class="admin-card admin-table-shell rounded-[2rem]">
        <div class="flex flex-col gap-3 border-b border-slate-200 px-6 py-5 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Paged Results</p>
                <p class="mt-2 text-sm text-slate-600">Showing @Model.StartItem-@Model.EndItem of @Model.TotalApplicants applicants</p>
            </div>
            <div class="flex flex-wrap items-center gap-2">
                <a asp-action="Index"
                   asp-all-route-data="@BuildRouteValues(Model, previousPage)"
                   class="@(Model.HasPreviousPage ? string.Empty : "pointer-events-none opacity-50") inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Previous
                </a>
                @foreach (var pageNumber in Model.VisiblePageNumbers)
                {
                    if (pageNumber == Model.PageNumber)
                    {
                        <span class="admin-gradient inline-flex items-center justify-center rounded-2xl px-4 py-2 text-sm font-semibold text-white shadow-soft">
                            @pageNumber
                        </span>
                    }
                    else
                    {
                        <a asp-action="Index"
                           asp-all-route-data="@BuildRouteValues(Model, pageNumber)"
                           class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                            @pageNumber
                        </a>
                    }
                }
                <a asp-action="Index"
                   asp-all-route-data="@BuildRouteValues(Model, nextPage)"
                   class="@(Model.HasNextPage ? string.Empty : "pointer-events-none opacity-50") inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                    Next
                </a>
            </div>
        </div>
        <div class="admin-table-scroll">
            <table class="admin-data-table min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50/80">
                    <tr>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Applicant</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Vacancy</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Profile</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Qualification</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">CV</th>
                        <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.06em] text-slate-500">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                    @if (applicants.Any())
                    {
                        @foreach (var applicant in applicants)
                        {
                            var experienceText = string.Format(CultureInfo.InvariantCulture, "{0:0.#}", applicant.NumberofExprianceYears ?? 0);

                            <tr class="transition hover:bg-slate-50/80">
                                <td class="px-6 py-5 align-top">
                                    <div class="space-y-2">
                                        <p class="text-sm font-semibold text-slate-950">@applicant.FullName</p>
                                        <p class="text-sm text-slate-600">@(string.IsNullOrWhiteSpace(applicant.PhoneNumber) ? "Contact not provided" : applicant.PhoneNumber)</p>
                                        <div class="flex flex-wrap gap-2">
                                            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">@(string.IsNullOrWhiteSpace(applicant.Gender) ? "Gender n/a" : applicant.Gender)</span>
                                            <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">@(string.IsNullOrWhiteSpace(applicant.PhoneNumber) ? "Phone n/a" : applicant.PhoneNumber)</span>
                                            @if (applicant.AreYouDisable == true)
                                            {
                                                <span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Disability disclosed</span>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 align-top">
                                    <p class="text-sm font-semibold text-slate-900">@(applicant.Job?.JobTitle ?? "-")</p>
                                    <p class="mt-2 text-sm text-slate-600">Applied @(applicant.RegistrationDate?.ToString("MMM dd, yyyy") ?? "-")</p>
                                </td>
                                <td class="px-6 py-5 align-top text-sm text-slate-700">
                                    <p class="font-semibold text-slate-900">@(applicant.Reg?.RegionName ?? "-")</p>
                                    <p class="mt-2 text-slate-500">@((string.IsNullOrWhiteSpace(applicant.ZoneSubcity) ? "-" : applicant.ZoneSubcity) + (string.IsNullOrWhiteSpace(applicant.Worede) ? string.Empty : $" / {applicant.Worede}"))</p>
                                    <p class="mt-2 text-slate-500">@(string.IsNullOrWhiteSpace(applicant.Nation) ? "Nationality n/a" : applicant.Nation)</p>
                                </td>
                                <td class="px-6 py-5 align-top text-sm text-slate-700">
                                    <p class="font-semibold text-slate-900">@experienceText years</p>
                                    <p class="mt-2 text-slate-500">@(string.IsNullOrWhiteSpace(applicant.EducationLevel) ? "Education n/a" : applicant.EducationLevel)</p>
                                    <p class="mt-2 text-slate-500">CGPA @(applicant.Cgpa?.ToString("0.00", CultureInfo.InvariantCulture) ?? "n/a")</p>
                                </td>
                                <td class="px-6 py-5 align-top">
                                    @if (!string.IsNullOrWhiteSpace(applicant.Cvfile))
                                    {
                                        <a asp-action="DocumentViewer"
                                           asp-controller="DocumentViewer"
                                           asp-route-path="@applicant.Cvfile"
                                           asp-route-methodController="Applicants"
                                           asp-route-method="Index"
                                           class="inline-flex rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                                            View CV
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-sm text-slate-500">No file</span>
                                    }
                                </td>
                                <td class="px-6 py-5 align-top">
                                    <div class="flex flex-wrap gap-2">
                                        <a asp-action="Details" asp-route-id="@applicant.ApplyId" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">View</a>
                                        <a asp-action="Delete" asp-route-id="@applicant.ApplyId" class="rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center">
                                <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">No applicants found</p>
                                <p class="mt-3 text-base leading-7 text-slate-600">Adjust the shortlist filters or wait for new submissions to arrive.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
