@{
    // A single computed title keeps metadata predictable while still allowing individual pages to override the prefix.
    var pageTitle = string.IsNullOrWhiteSpace(ViewData["Title"] as string)
        ? "EBC Job Portal"
        : $"{ViewData["Title"]} | EBC Job Portal";

    // Sensible fallback metadata prevents empty tags from degrading search and social previews.
    var pageDescription = ViewData["Description"] as string ?? "Discover current career opportunities at Ethiopian Broadcasting Corporation.";
    var pageKeywords = ViewData["Keywords"] as string ?? "EBC, Ethiopian Broadcasting Corporation, careers, jobs, vacancies";
    var pageUrl = ViewData["Url"] as string ?? $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    var pageImage = ViewData["Image"] as string ?? Url.Content("~/assets/images/rounded_logo-removebg-preview.png");
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />
    <meta name="keywords" content="@pageKeywords" />
    <meta name="theme-color" content="#023f5b" />

    @* Canonical tags stay optional because not every local environment has a public absolute URL. *@
    @if (ViewData["Canonical"] is string canonicalUrl && !string.IsNullOrWhiteSpace(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
    }

    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@pageDescription" />
    <meta property="og:url" content="@pageUrl" />
    <meta property="og:site_name" content="EBC Job Portal" />
    <meta property="og:image" content="@pageImage" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@pageDescription" />
    <meta name="twitter:image" content="@pageImage" />

    @* The favicon remains local so the portal branding still works offline and in development. *@
    <link rel="icon" type="image/png" href="~/assets/images/rounded_logo-removebg-preview.png" />

    @* Outfit and DM Sans give the portal a cleaner, calmer tone than the previous font pairings. *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet" />

    @* Tailwind via CDN is used here exactly as requested to speed up the redesign without adding a local build step first. *@
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        // Tailwind is configured inline so the design tokens are immediately available in Razor views during Hot Reload.
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            DEFAULT: "#023f5b",
                            light: "#0a5f84",
                            ink: "#012d41",
                            mist: "#e7f0f5"
                        }
                    },
                    fontFamily: {
                        sans: ["DM Sans", "system-ui", "sans-serif"],
                        display: ["Outfit", "DM Sans", "system-ui", "sans-serif"]
                    },
                    boxShadow: {
                        soft: "0 20px 60px rgba(2, 63, 91, 0.12)"
                    }
                }
            }
        };
    </script>

    @* Portal-specific CSS variables and reusable component classes live outside Tailwind so brand tokens stay centralized. *@
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tw-fallback.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="portal-body min-h-screen bg-slate-50 text-slate-900 antialiased">
    @* Flex column layout keeps the footer pinned to the bottom on shorter pages without custom JS. *@
    <div class="relative flex min-h-screen flex-col overflow-x-clip">
        @* Decorative background orbs add depth while preserving the minimalist palette. *@
        <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[36rem] bg-[radial-gradient(circle_at_top,_rgba(10,95,132,0.18),_transparent_45%),radial-gradient(circle_at_right,_rgba(2,63,91,0.10),_transparent_30%)]"></div>

        @* Sticky positioning and backdrop blur create the requested glass navigation effect while preserving readability. *@
        <header class="sticky top-0 z-50 border-b border-white/60 bg-white/70 backdrop-blur-xl">
            <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
                @* The brand link pairs the logo with concise naming so the header stays elegant and compact. *@
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 text-slate-900 transition hover:opacity-90">
                    <img src="~/assets/images/rounded_logo-removebg-preview.png" alt="EBC logo" class="h-11 w-11 rounded-2xl border border-slate-200/80 bg-white p-1 shadow-sm" />
                    <span class="flex flex-col">
                        <span class="font-display text-xl font-extrabold tracking-tight text-slate-950">EBC Job Portal</span>
                        <span class="text-xs font-medium uppercase tracking-[0.12em] text-slate-500">Careers at Ethiopian Broadcasting Corporation</span>
                    </span>
                </a>

                @* Hidden-on-mobile navigation avoids cramped layouts and lets the mobile sheet handle smaller screens. *@
                <nav class="hidden items-center gap-2 md:flex" aria-label="Primary">
                    <a asp-controller="Home" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-950">Home</a>
                    <a asp-controller="AllJobs" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-950">Open Roles</a>
                    <a asp-controller="Home" asp-action="Contact" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-950">Contact</a>
                    <a href="https://www.ebc.et" target="_blank" rel="noreferrer" class="rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-slate-100 hover:text-slate-950">EBC Website</a>
                </nav>

                @* The mobile toggle keeps the nav accessible without bringing in a larger JS framework. *@
                <button id="mobile-menu-button"
                        type="button"
                        class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white p-3 text-slate-700 shadow-sm transition hover:border-slate-300 hover:text-slate-950 md:hidden"
                        aria-controls="mobile-menu"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
                    </svg>
                </button>
            </div>

            @* The mobile sheet mirrors the desktop IA so navigation remains consistent across breakpoints. *@
            <div id="mobile-menu" class="hidden border-t border-slate-200/80 bg-white/90 px-4 py-4 backdrop-blur-xl md:hidden">
                <nav class="flex flex-col gap-2" aria-label="Mobile">
                    <a asp-controller="Home" asp-action="Index" class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-slate-950">Home</a>
                    <a asp-controller="AllJobs" asp-action="Index" class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-slate-950">Open Roles</a>
                    <a asp-controller="Home" asp-action="Contact" class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-slate-950">Contact</a>
                    <a href="https://www.ebc.et" target="_blank" rel="noreferrer" class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 hover:text-slate-950">EBC Website</a>
                </nav>
            </div>
        </header>

        @* Growing main content takes remaining viewport height so each page can breathe without layout hacks. *@
        <main class="flex-1">
            @RenderBody()
        </main>

        @* The footer stays intentionally quiet so it supports the layout instead of competing with content. *@
        <footer class="border-t border-slate-200 bg-white/80">
            <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 py-10 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                <div class="max-w-2xl">
                    <p class="font-display text-lg font-bold tracking-tight text-slate-950">EBC Job Portal</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">A clean, candidate-first experience for discovering and applying to opportunities at Ethiopian Broadcasting Corporation.</p>
                </div>
                <div class="flex flex-col gap-3 text-sm text-slate-500 sm:flex-row sm:items-center sm:gap-6">
                    <a href="https://www.ebc.et" target="_blank" rel="noreferrer" class="transition hover:text-slate-900">Main Website</a>
                    <span>&copy; @DateTime.Now.Year EBC. All rights reserved.</span>
                </div>
            </div>
        </footer>
    </div>

    <script>
        // Grabbing the button once avoids repeated DOM lookups during interaction.
        const mobileMenuButton = document.getElementById("mobile-menu-button");

        // Grabbing the menu once keeps the toggle logic small and easy to follow.
        const mobileMenu = document.getElementById("mobile-menu");

        // The click handler only manages visibility and accessibility state, which keeps the behavior predictable.
        if (mobileMenuButton && mobileMenu) {
            mobileMenuButton.addEventListener("click", () => {
                // Reading the current state from the DOM keeps the JS aligned with server-rendered markup.
                const isExpanded = mobileMenuButton.getAttribute("aria-expanded") === "true";

                // The hidden utility is toggled directly so the menu works without any JS framework dependency.
                mobileMenu.classList.toggle("hidden", isExpanded);

                // Updating aria-expanded keeps screen readers informed about the current state of the control.
                mobileMenuButton.setAttribute("aria-expanded", (!isExpanded).toString());
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Component.InvokeAsync("NToastNotify")
    @await Component.InvokeAsync("Notyf")
</body>
</html>
