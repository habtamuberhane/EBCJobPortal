@model IEnumerable<EBCJobPortal.Models.TblJobList>

@{
    ViewData["title"] = @ViewBag.title;
    ViewData["description"] = @ViewBag.description;
    ViewData["url"] = @ViewBag.url;
    ViewData["image"] = @ViewBag.image;
    ViewData["canonical"] = @ViewBag.canonical;
    ViewData["keywords"] = @ViewBag.keywords;
    ViewData["facebooktag"] = @ViewBag.facebooktag;
}
<div class="page-breadcrumb">
    <div class="row">
        <div class="col-5 align-self-center">
            <h4 class="page-title">Vacancies</h4>
        </div>
        <div class="col-7 align-self-center">
            <div class="d-flex align-items-center justify-content-end">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-action="Index">Vacancies</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Lists</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<div class="container-fluid">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-12 mb-4">
                <div class="card w-100">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-12">
                                <h5 class="card-title mb-2">@Html.DisplayFor(modelItem => item.JobTitle)</h5>

                                <div class="job-description mb-3">
                                    <div class="description-text" >

                                        @Html.Raw(item.JobDescription),
                                    </div>
                                </div>

                                <div class="job-meta d-flex flex-wrap gap-3">
                                    <div class="meta-item d-flex align-items-center">
                                        <span class="text-muted me-2">
                                            <i class="fas fa-calendar-plus me-1"></i> Posted:
                                        </span>
                                        <span class="text-dark fw-medium">
                                            @if (item.PostedDate.HasValue)
                                            {
                                                @item.PostedDate.Value.ToString("MMM dd, yyyy")
                                            }
                                        </span>
                                    </div>
                                    <div class="meta-item d-flex align-items-center">
                                        <span class="text-muted me-2">
                                            <i class="fas fa-calendar-times me-1"></i> Expires:
                                        </span>
                                        <span class="text-dark fw-medium">
                                            @if (item.ExpiredDate.HasValue)
                                            {
                                                @item.ExpiredDate.Value.ToString("MMM dd, yyyy")
                                            }
                                        </span>
                                    </div>
                                    @if (item.RequiredNumber.HasValue)
                                    {
                                        <div class="meta-item d-flex align-items-center">
                                            <span class="text-muted me-2">
                                                <i class="fas fa-users me-1"></i> Required:
                                            </span>
                                            <span class="badge bg-primary rounded-pill">
                                                @item.RequiredNumber.Value
                                            </span>
                                        </div>
                                    }
                                </div>
                                <div class="col-md-2 text-md-end  mt-md-0">
                                    <div class="d-flex flex-column gap-2">
                                        <a asp-action="Create" asp-route-id="@item.JobId"
                                           class="btn btn-primary btn-lg px-4">
                                            <i class="fas fa-paper-plane me-2"></i> Apply Now
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    @{
                        var isExpired = item.ExpiredDate.HasValue && item.ExpiredDate.Value < DateTime.Now;
                        var statusClass = isExpired ? "bg-danger" : "bg-success";
                        var statusText = isExpired ? "Expired" : "Active";
                    }
                    <div class="card-footer bg-light p-0">
                        <div class="d-flex justify-content-between align-items-center px-4 py-2">
                            <small class="text-muted">
                                <i class="fas fa-clock me-1"></i>
                                @if (item.PostedDate.HasValue)
                                {
                                    var daysAgo = (DateTime.Now - item.PostedDate.Value).Days;
                                    <span>Posted @daysAgo day@(daysAgo != 1 ? "s" : "") ago</span>
                                }
                            </small>
                            <span class="badge @statusClass rounded-pill px-3 py-1">
                                <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>
                                @statusText
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="fas fa-briefcase fa-3x text-muted mb-3"></i>
                        <h4 class="text-muted">No vacancies available</h4>
                        <p class="text-muted">Check back later for new job opportunities.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    /* Card styling */
    .card {
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        transition: all 0.3s ease;
        width: 100% !important;
        margin: 0;
    }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.1);
            border-color: #4e73df;
        }

    .card-body {
        padding: 1.5rem !important;
    }

    .card-title {
        font-weight: 600;
        color: #2d3748;
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
    }

    /* Job description */
    .description-text {
        color: #4a5568;
        line-height: 1.6;
    }

    /* Meta information */
    .job-meta {
        margin-top: 1rem;
    }

    .meta-item {
        font-size: 0.9rem;
        padding: 0.25rem 0;
    }

    .badge.bg-primary {
        background-color: #4e73df !important;
        padding: 0.25rem 0.75rem;
    }

    /* Button styling */
    .btn-primary {
        background-color: #4e73df;
        border-color: #4e73df;
        font-weight: 500;
    }

        .btn-primary:hover {
            background-color: #2e59d9;
            border-color: #2653d4;
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(78, 115, 223, 0.3);
        }

    .btn-outline-secondary {
        color: #6c757d;
        border-color: #6c757d;
        font-weight: 500;
    }

        .btn-outline-secondary:hover {
            background-color: #6c757d;
            border-color: #6c757d;
            color: white;
        }

    /* Status badges */
    .badge.bg-success {
        background-color: #1cc88a !important;
    }

    .badge.bg-danger {
        background-color: #e74a3b !important;
    }

    /* Card footer */
    .card-footer {
        border-top: 1px solid #f0f0f0;
        background-color: #f8f9fa !important;
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .card-body {
            padding: 1rem !important;
        }

        .btn-lg {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }

        .card-title {
            font-size: 1.1rem;
        }

        .job-meta {
            flex-direction: column;
            gap: 0.5rem !important;
        }
    }

    /* Animation for hover effects */
    .btn, .card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Custom scrollbar for description */
    .description-text::-webkit-scrollbar {
        width: 4px;
    }

    .description-text::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    .description-text::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 10px;
    }

    /* Ensure full width */
    .col-12 {
        padding-left: 0;
        padding-right: 0;
        width: 100%;
    }

    .row {
        margin-left: 0;
        margin-right: 0;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Add click handler for view details buttons
        document.querySelectorAll('.view-details-btn').forEach(button => {
            button.addEventListener('click', function () {
                const jobId = this.getAttribute('data-job-id');
                // You can implement modal or redirect here
                window.location.href = `/Jobs/Details/${jobId}`;
            });
        });

        // Add hover effects
        const cards = document.querySelectorAll('.card');
        cards.forEach(card => {
            card.addEventListener('mouseenter', function () {
                this.style.zIndex = '10';
            });

            card.addEventListener('mouseleave', function () {
                this.style.zIndex = '1';
            });
        });
    });
</script>