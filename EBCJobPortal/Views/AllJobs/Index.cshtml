@model VacanciesIndexViewModel
@using System.Text.RegularExpressions

@{
    // This page title replaces the old repeated breadcrumb wording with a cleaner heading.
    ViewData["Title"] = "Open Vacancies";
    ViewData["Description"] = "Browse active vacancies currently available at Ethiopian Broadcasting Corporation.";
    var applicationStatus = TempData["ApplicationStatus"] as string;
    var applicationMessage = TempData["ApplicationMessage"] as string;
    var appliedJobIds = (Context.Session.GetString("AppliedJobs") ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(value => int.TryParse(value, out var parsedId) ? parsedId : (int?)null)
        .Where(parsedId => parsedId.HasValue)
        .Select(parsedId => parsedId!.Value)
        .ToHashSet();

    // This helper removes stored HTML so summaries render with clean spacing and no broken markup.
    static string StripHtml(string? input) => string.IsNullOrWhiteSpace(input)
        ? string.Empty
        : Regex.Replace(input, "<.*?>", string.Empty).Trim();

    // This helper keeps list cards compact and consistent.
    static string TruncateText(string value, int maxLength) => value.Length <= maxLength
        ? value
        : $"{value[..maxLength].TrimEnd()}...";
}

@* The section replaces the old dashboard breadcrumb block with a single calm page introduction. *@
<section class="pb-20 pt-14">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 max-w-3xl space-y-3">
            @* The eyebrow creates page hierarchy without repeating the same word three times. *@
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">EBC Careers</p>
            <h1 class="font-display text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">Open vacancies</h1>
            <p class="text-base leading-7 text-slate-600">Current opportunities available on the client portal.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(applicationMessage))
        {
            <div class="mb-8 rounded-[1.75rem] border px-6 py-5 @(string.Equals(applicationStatus, "success", StringComparison.OrdinalIgnoreCase) ? "border-emerald-200 bg-emerald-50 text-emerald-800" : "border-amber-200 bg-amber-50 text-amber-800")">
                <p class="text-sm font-semibold uppercase tracking-[0.08em]">Application status</p>
                <p class="mt-2 text-sm leading-7">@applicationMessage</p>
            </div>
        }

        @if (Model.Jobs.Any())
        {
            <div class="mb-8 flex flex-col gap-4 rounded-[1.75rem] border border-slate-200 bg-white px-6 py-5 shadow-soft sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Vacancy listing</p>
                    <p class="mt-2 text-sm leading-7 text-slate-600">
                        Showing @Model.StartItem-@Model.EndItem of @Model.TotalJobs active vacancies.
                    </p>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="flex items-center gap-3">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.PageNumber - 1)"
                               class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                                Previous
                            </a>
                        }
                        else
                        {
                            <span class="inline-flex cursor-not-allowed items-center justify-center rounded-2xl border border-slate-200 bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-400">
                                Previous
                            </span>
                        }

                        <span class="text-sm font-semibold text-slate-600">
                            Page @Model.PageNumber of @Model.TotalPages
                        </span>

                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.PageNumber + 1)"
                               class="portal-gradient inline-flex items-center justify-center rounded-2xl px-4 py-2 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                                Next
                            </a>
                        }
                        else
                        {
                            <span class="inline-flex cursor-not-allowed items-center justify-center rounded-2xl bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-500">
                                Next
                            </span>
                        }
                    </div>
                }
            </div>

            @* The listing grid uses even gaps so the page feels orderly and less crowded. *@
            <div class="grid gap-6 lg:grid-cols-2">
                @foreach (var item in Model.Jobs)
                {
                    // Cleaning the description first gives the preview a stable text rhythm.
                    var plainDescription = StripHtml(item.JobDescription);

                    // The shorter preview prevents oversized cards and keeps the listing page scannable.
                    var previewDescription = string.IsNullOrWhiteSpace(plainDescription)
                        ? "Open the vacancy to review the full role description and application requirements."
                        : TruncateText(plainDescription, 170);

                    <article class="portal-job-card flex h-full flex-col rounded-[2rem] p-6">
                        @* The title block is kept simple so the eye lands on the role name first. *@
                        <div class="space-y-3">
                            <span class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-brand">
                                Open role
                            </span>
                            <h2 class="font-display text-2xl font-bold leading-tight tracking-tight text-slate-950">@item.JobTitle</h2>
                        </div>

                        @* Consistent line-height solves the uneven text spacing from the previous version. *@
                        <p class="mt-5 text-sm leading-7 text-slate-600">@previewDescription</p>

                        @* Compact metadata cards keep the information aligned and easy to compare. *@
                        <div class="mt-6 grid gap-3 sm:grid-cols-3">
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Posted</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@((item.PostedDate ?? DateTime.Today).ToString("MMM dd, yyyy"))</p>
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Deadline</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@((item.ExpiredDate ?? DateTime.Today).ToString("MMM dd, yyyy"))</p>
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Positions</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@(item.RequiredNumber ?? 1)</p>
                            </div>
                        </div>

                        @* The action row stays minimal and takes candidates straight into the application flow. *@
                        <div class="mt-6 border-t border-slate-200 pt-6">
                            @if (appliedJobIds.Contains(item.JobId))
                            {
                                <span class="inline-flex cursor-not-allowed items-center justify-center rounded-2xl bg-emerald-100 px-5 py-3 text-sm font-semibold text-emerald-700">
                                    Applied
                                </span>
                            }
                            else
                            {
                                <a asp-controller="AllJobs"
                                   asp-action="Create"
                                   asp-route-id="@item.JobId"
                                   class="portal-gradient inline-flex items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                                    Apply now
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="mt-8 flex flex-col items-center justify-between gap-4 rounded-[1.75rem] border border-slate-200 bg-white px-6 py-5 shadow-soft sm:flex-row">
                    <p class="text-sm leading-7 text-slate-600">
                        Continue browsing to see the rest of the open roles.
                    </p>

                    <div class="flex items-center gap-3">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.PageNumber - 1)"
                               class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                                Previous
                            </a>
                        }

                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index"
                               asp-route-page="@(Model.PageNumber + 1)"
                               class="portal-gradient inline-flex items-center justify-center rounded-2xl px-4 py-2 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                                Next
                            </a>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            @* The empty state uses the same spacing rhythm as the rest of the portal for consistency. *@
            <div class="portal-surface rounded-[2rem] px-8 py-14 text-center">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">No active vacancies</p>
                <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-slate-950">There are no open roles at the moment.</h2>
                <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-600">Please check back later for new opportunities.</p>
            </div>
        }
    </div>
</section>
