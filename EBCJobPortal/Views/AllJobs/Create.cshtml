@model EBCJobPortal.ViewModel.ApplicantModel

@{
    ViewData["Title"] = "Apply";
    ViewData["Description"] = "Complete your application for the selected EBC vacancy.";
    var formStatus = ViewData["FormStatus"] as string;
    var formMessage = ViewData["FormMessage"] as string;
}

<section class="pb-20 pt-14">
    <div class="portal-application-shell mx-auto w-full px-4 sm:px-6 lg:px-8">
        <div class="portal-application-card rounded-[2rem] px-6 py-8 sm:px-8">
            <div class="flex flex-col gap-6 border-b border-slate-200 pb-8 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl space-y-3">
                    <p class="text-sm font-semibold uppercase tracking-[0.12em] text-brand">Application Form</p>
                    <h1 class="font-display text-4xl font-bold tracking-tight text-slate-950">Apply for @Model.JobTitle</h1>
                    <p class="text-base leading-7 text-slate-600">Complete the form carefully and submit your application. You can optionally attach one combined PDF with your CV and supporting credentials.</p>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm text-slate-600 shadow-sm">
                    <p class="font-semibold text-slate-900">Before you submit</p>
                    <p class="mt-2 leading-6">Use your active phone number. If you want to attach supporting documents, upload them as a single PDF file.</p>
                </div>
            </div>

            <form asp-action="Create" method="post" enctype="multipart/form-data" class="portal-application-form mt-8">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="JobId" />
                <input type="hidden" asp-for="JobTitle" />

                @if (!string.IsNullOrWhiteSpace(formMessage))
                {
                    <div class="rounded-2xl border px-4 py-3 text-sm @(string.Equals(formStatus, "warning", StringComparison.OrdinalIgnoreCase) ? "border-amber-200 bg-amber-50 text-amber-800" : "border-red-200 bg-red-50 text-red-700")">
                        @formMessage
                    </div>
                }

                <div asp-validation-summary="ModelOnly" class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>

                <section class="space-y-5">
                    <div class="space-y-2">
                        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Personal Information</p>
                        <h2 class="font-display text-2xl font-bold tracking-tight text-slate-950">Tell us about yourself</h2>
                    </div>

                    <div class="portal-form-grid portal-form-grid--two">
                        <div class="space-y-2">
                            <label asp-for="FullName" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="FullName" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="FullName" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="PhoneNumber" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="PhoneNumber" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="PhoneNumber" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="BirthDate" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="BirthDate" type="date" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="BirthDate" class="text-sm text-red-600"></span>
                        </div>
                    </div>

                    <div class="portal-form-grid portal-form-grid--three">
                        <div class="space-y-3">
                            <label asp-for="Gender" class="text-sm font-semibold text-slate-700"></label>
                            <div class="portal-choice-grid sm:grid-cols-2">
                                @foreach (var gender in Model.Genders)
                                {
                                    <label class="portal-choice-card flex gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">
                                        <input type="radio" asp-for="Gender" value="@gender" class="h-4 w-4 border-slate-300 text-brand focus:ring-brand/20" />
                                        <span>@gender</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Gender" class="text-sm text-red-600"></span>
                        </div>

                        <div class="space-y-3">
                            <label asp-for="MaritalStatus" class="text-sm font-semibold text-slate-700"></label>
                            <div class="portal-choice-grid">
                                @foreach (var status in Model.MaritalStatuses)
                                {
                                    <label class="portal-choice-card flex gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">
                                        <input type="radio" asp-for="MaritalStatus" value="@status" class="h-4 w-4 border-slate-300 text-brand focus:ring-brand/20" />
                                        <span>@status</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="MaritalStatus" class="text-sm text-red-600"></span>
                        </div>

                        <div class="space-y-3">
                            <label asp-for="Disable" class="text-sm font-semibold text-slate-700">Any disability?</label>
                            <div class="portal-choice-grid sm:grid-cols-2">
                                @foreach (var disability in Model.Disablities)
                                {
                                    <label class="portal-choice-card flex gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700">
                                        <input type="radio" asp-for="Disable" value="@disability" class="h-4 w-4 border-slate-300 text-brand focus:ring-brand/20" />
                                        <span>@disability</span>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Disable" class="text-sm text-red-600"></span>
                        </div>
                    </div>

                </section>

                <section class="portal-form-section">
                    <div class="space-y-2">
                        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Location</p>
                        <h2 class="font-display text-2xl font-bold tracking-tight text-slate-950">Where can we reach you?</h2>
                    </div>

                    <div class="portal-form-grid portal-form-grid--two">
                        <div class="space-y-2">
                            <label asp-for="Nation" class="text-sm font-semibold text-slate-700"></label>
                            @Html.DropDownListFor(model => model.Nation, new SelectList(Model.Nations, "Value", "Text", Model.Nation), "-- Select nationality --", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
                            <span asp-validation-for="Nation" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="Regid" class="text-sm font-semibold text-slate-700"></label>
                            @Html.DropDownListFor(model => model.Regid, new SelectList(Model.Regions, "Value", "Text"), "-- Select region --", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
                            <span asp-validation-for="Regid" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="ZoneSubcity" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="ZoneSubcity" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="ZoneSubcity" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="Worede" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="Worede" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="Worede" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="HouseNumber" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="HouseNumber" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="HouseNumber" class="text-sm text-red-600"></span>
                        </div>
                    </div>
                </section>

                <section class="portal-form-section">
                    <div class="space-y-2">
                        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Education</p>
                        <h2 class="font-display text-2xl font-bold tracking-tight text-slate-950">Academic background</h2>
                    </div>

                    <div class="portal-form-grid portal-form-grid--two">
                        <div class="space-y-2">
                            <label asp-for="EducationField" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="EducationField" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" placeholder="Example: Journalism, Accounting, Computer Science" />
                            <span asp-validation-for="EducationField" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="EducationLevel" class="text-sm font-semibold text-slate-700"></label>
                            @Html.DropDownListFor(model => model.EducationLevel, new SelectList(Model.EducationLevels, "Value", "Text", Model.EducationLevel), "-- Select education level --", new { @class = "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" })
                            <span asp-validation-for="EducationLevel" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="Institution" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="Institution" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="Institution" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="GraduationYear" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="GraduationYear" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="GraduationYear" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="Cgpa" class="text-sm font-semibold text-slate-700"></label>
                            <input asp-for="Cgpa" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="Cgpa" class="text-sm text-red-600"></span>
                        </div>
                    </div>
                </section>

                <section class="portal-form-section">
                    <div class="space-y-2">
                        <p class="text-sm font-semibold uppercase tracking-[0.08em] text-brand">Experience</p>
                        <h2 class="font-display text-2xl font-bold tracking-tight text-slate-950">Professional details</h2>
                        <p class="text-sm leading-7 text-slate-600">If you are a fresh graduate, enter <span class="font-semibold text-slate-900">0</span> years of experience and leave the optional work fields blank.</p>
                    </div>

                    <div class="portal-form-grid portal-form-grid--two">
                        <div class="space-y-2">
                            <label asp-for="NumberofExprianceYears" class="text-sm font-semibold text-slate-700">Years of relevant experience</label>
                            <input asp-for="NumberofExprianceYears" type="number" step="0.1" min="0" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <span asp-validation-for="NumberofExprianceYears" class="text-sm text-red-600"></span>
                        </div>
                        <div class="space-y-2">
                            <label asp-for="CurrentWorkingCompany" class="text-sm font-semibold text-slate-700">Current or most recent employer</label>
                            <input asp-for="CurrentWorkingCompany" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                        </div>
                        <div class="space-y-2">
                            <label asp-for="PositionTitle" class="text-sm font-semibold text-slate-700">Current or most recent job title</label>
                            <input asp-for="PositionTitle" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" />
                        </div>
                        <div class="space-y-2">
                            <label asp-for="MonthlySalary" class="text-sm font-semibold text-slate-700">Current or most recent monthly salary</label>
                            <input asp-for="MonthlySalary" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-brand focus:ring-4 focus:ring-brand/10" placeholder="Optional" />
                        </div>
                        <div class="space-y-2 md:col-span-2">
                            <label for="Cvfile" class="text-sm font-semibold text-slate-700">CV and supporting documents (optional PDF)</label>
                            <input id="Cvfile" name="Cvfile" type="file" accept=".pdf,application/pdf" data-val="false" class="w-full rounded-2xl border border-dashed border-slate-300 bg-white px-4 py-3 text-sm text-slate-700 outline-none transition file:mr-4 file:rounded-xl file:border-0 file:bg-brand/10 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-brand hover:border-brand/40 focus:border-brand focus:ring-4 focus:ring-brand/10" />
                            <p class="text-sm leading-6 text-slate-500">You can leave this empty and still submit the application.</p>
                            <span asp-validation-for="Cvfile" class="text-sm text-red-600"></span>
                        </div>
                    </div>
                </section>

                <div class="portal-form-actions">
                    <a asp-action="Index" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:text-slate-950">
                        Back to vacancies
                    </a>
                    <button type="submit" class="portal-gradient inline-flex items-center justify-center rounded-2xl px-6 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                        Submit application
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
