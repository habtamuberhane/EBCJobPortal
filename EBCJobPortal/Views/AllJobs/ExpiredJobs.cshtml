@model IEnumerable<EBCJobPortal.Models.TblJobList>

@{
    ViewData["Title"] = "Index";
}
<div class="page-breadcrumb">
    <div class="row">
        <div class="col-5 align-self-center">
            <h4 class="page-title">Vacancies</h4>
        </div>
        <div class="col-7 align-self-center">
            <div class="d-flex align-items-center justify-content-end">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a asp-action="Index">Vacancies</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">Lists</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                <div class="card job-card h-100">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0 text-truncate" title="@item.JobTitle">
                            @Html.DisplayFor(modelItem => item.JobTitle)
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="job-description mb-3">
                            <small class="text-muted d-block mb-2">Description:</small>
                            <div class="description-content" style="max-height: 80px; overflow: hidden; position: relative;">
                                @Html.Raw(item.JobDescription)
                                <div class="fade-out"></div>
                            </div>
                        </div>

                        <div class="job-details">
                            <div class="detail-item d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">
                                    <i class="fas fa-users me-1"></i> Required:
                                </span>
                                <span class="badge bg-primary rounded-pill">
                                    @Html.DisplayFor(modelItem => item.RequiredNumber)
                                </span>
                            </div>

                            <div class="detail-item d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">
                                    <i class="fas fa-calendar-plus me-1"></i> Posted:
                                </span>
                                <small class="text-dark">
                                    @if (item.PostedDate.HasValue)
                                    {
                                        @item.PostedDate.Value.ToString("MMM dd, yyyy")
                                    }
                                </small>
                            </div>

                            <div class="detail-item d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">
                                    <i class="fas fa-calendar-times me-1"></i> Expires:
                                </span>
                                <small class="text-dark">
                                    @if (item.ExpiredDate.HasValue)
                                    {
                                        @item.ExpiredDate.Value.ToString("MMM dd, yyyy")
                                    }
                                </small>
                            </div>
                        </div>

                        <div class="status-indicator mt-3">
                            @{
                                var isExpired = item.ExpiredDate.HasValue && item.ExpiredDate.Value < DateTime.Now;
                                var statusClass = isExpired ? "bg-danger" : "bg-success";
                                var statusText = isExpired ? "Expired" : "Active";
                            }
                            <span class="badge @statusClass float-end">@statusText</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <div class="d-grid">
                            <button class="btn btn-outline-primary view-details-btn" data-job-id="@item.JobId">
                                <i class="fas fa-eye me-1"></i> View Details
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        <div class="empty-state-icon mb-3">
                            <i class="fas fa-briefcase fa-4x text-muted"></i>
                        </div>
                        <h4 class="text-muted mb-3">No Job Vacancies Available</h4>
                        <p class="text-muted mb-4">Currently there are no open positions. Please check back later.</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .job-card {
        border: 1px solid #e0e0e0;
        border-radius: 10px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .job-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        border-color: #4e73df;
    }

    .card-header {
        border-bottom: 1px solid #e0e0e0;
        padding: 15px 20px;
    }

    .card-title {
        font-weight: 600;
        color: #2e3a59;
    }

    .fade-out {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 30px;
        background: linear-gradient(transparent, white);
    }

    .description-content {
        line-height: 1.5;
        font-size: 0.9rem;
    }

    .job-details {
        background-color: #f8fafc;
        border-radius: 8px;
        padding: 15px;
        margin: 15px 0;
    }

    .detail-item {
        font-size: 0.9rem;
    }

    .badge.bg-primary {
        background-color: #4e73df !important;
        min-width: 30px;
        padding: 5px 10px;
    }

    .badge.bg-success {
        background-color: #1cc88a !important;
    }

    .badge.bg-danger {
        background-color: #e74a3b !important;
    }

    .view-details-btn {
        transition: all 0.3s ease;
        border-width: 2px;
    }

    .view-details-btn:hover {
        background-color: #4e73df;
        color: white;
        transform: translateY(-2px);
    }

    .card-footer {
        padding: 15px 20px;
    }

    .empty-state-icon {
        opacity: 0.6;
    }

    @@media (max-width: 768px) {
        .col-md-6 {
            padding-left: 8px;
            padding-right: 8px;
        }

        .job-card {
            margin-bottom: 16px;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Add click handler for view details buttons
        document.querySelectorAll('.view-details-btn').forEach(button => {
            button.addEventListener('click', function() {
                const jobId = this.getAttribute('data-job-id');
                // You can implement the view details functionality here
                // For example: window.location.href = `/Jobs/Details/${jobId}`;
                console.log('View details for job ID:', jobId);

                // Show a temporary alert (replace with actual navigation/modal)
                alert('Viewing details for job ID: ' + jobId + '\n\nIn a real application, this would navigate to the job details page or open a modal.');
            });
        });
    });
</script>