@model HomeIndexViewModel
@using System.Text.RegularExpressions

@{
    // The page metadata is kept concise so the home page feels like a calm entry point into the portal.
    ViewData["Title"] = "Careers";
    ViewData["Description"] = "Explore current vacancies at Ethiopian Broadcasting Corporation.";
    ViewData["Keywords"] = "EBC careers, EBC vacancies, Ethiopian Broadcasting Corporation jobs";
    var appliedJobIds = (Context.Session.GetString("AppliedJobs") ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(value => int.TryParse(value, out var parsedId) ? parsedId : (int?)null)
        .Where(parsedId => parsedId.HasValue)
        .Select(parsedId => parsedId!.Value)
        .ToHashSet();

    // This helper removes stored HTML so the preview text stays clean and spacing remains consistent.
    static string StripHtml(string? input) => string.IsNullOrWhiteSpace(input)
        ? string.Empty
        : Regex.Replace(input, "<.*?>", string.Empty).Trim();

    // This helper keeps card summaries short enough to preserve a minimal layout.
    static string TruncateText(string value, int maxLength) => value.Length <= maxLength
        ? value
        : $"{value[..maxLength].TrimEnd()}...";
}

@* The hero is intentionally restrained so the page opens with one clear message and a balanced visual. *@
<section class="relative isolate overflow-hidden">
    @* This container becomes two columns on large screens so the logo can sit neatly beside the copy. *@
    <div class="mx-auto grid w-full max-w-6xl gap-10 px-4 pb-16 pt-14 sm:px-6 sm:pb-20 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:px-8 lg:pt-20">
        <div class="max-w-3xl space-y-6">
            @* The eyebrow adds context without introducing visual clutter. *@
            <div class="inline-flex items-center rounded-full border border-brand/10 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-brand shadow-sm backdrop-blur">
                Ethiopian Broadcasting Corporation Careers
            </div>

            @* A short headline gives the page a confident first impression and restores the proper large-screen scale. *@
            <h1 class="font-display text-4xl font-extrabold leading-[1.06] tracking-tight text-slate-950 sm:text-5xl lg:text-6xl">
                Find your next role at EBC.
            </h1>

            @* The supporting copy keeps an even rhythm so the text feels calmer and more intentional. *@
            <p class="max-w-2xl text-base leading-7 text-slate-600 sm:text-lg sm:leading-8">
                Browse current opportunities, understand the role clearly, and move into the application process with less friction.
            </p>

            @* A single action keeps the hero focused on the primary goal of exploring jobs. *@
            <div class="flex flex-col gap-3 sm:flex-row">
                <a asp-controller="AllJobs"
                   asp-action="Index"
                   class="portal-gradient inline-flex items-center justify-center rounded-2xl px-6 py-4 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                    Browse Open Vacancies
                </a>
            </div>
        </div>

        <div class="flex justify-center lg:justify-end">
            @* The logo stage balances the hero visually while keeping the motion subtle and professional. *@
            <div class="portal-logo-stage relative flex h-[20rem] w-[20rem] items-center justify-center sm:h-[24rem] sm:w-[24rem]">
                @* Animated rings create a clean broadcast-inspired motion around the logo. *@
                <div class="portal-logo-ring portal-logo-ring--outer"></div>
                <div class="portal-logo-ring portal-logo-ring--middle"></div>

                @* The core disc uses the same frosted visual language as the rest of the portal. *@
                <div class="portal-logo-core portal-surface relative flex h-56 w-56 items-center justify-center rounded-full sm:h-64 sm:w-64">
                    <img src="~/assets/images/rounded_logo-removebg-preview.png"
                         alt="Ethiopian Broadcasting Corporation logo"
                         class="portal-logo-mark h-28 w-28 object-contain sm:h-32 sm:w-32" />
                </div>
            </div>
        </div>
    </div>
</section>

@* The featured jobs section remains focused so the page still feels minimal after the hero. *@
<section class="pb-20">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 max-w-2xl space-y-3">
            @* This small label creates structure without the heaviness of breadcrumb-style UI. *@
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">Open vacancies</p>
            <h2 class="font-display text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">Current opportunities</h2>
            <p class="text-base leading-7 text-slate-600">A focused view of the latest roles available right now.</p>
            <a asp-controller="AllJobs"
               asp-action="Index"
               class="inline-flex items-center text-sm font-semibold text-brand transition hover:text-brand-light">
                See all jobs
            </a>
        </div>

        @if (Model.FeaturedJobs.Count > 0)
        {
            @* The grid uses steady spacing so every card aligns consistently across breakpoints. *@
            <div class="grid gap-6 lg:grid-cols-2">
                @foreach (var job in Model.FeaturedJobs)
                {
                    // Stripping HTML first prevents broken spacing and tag fragments in the summary line.
                    var plainDescription = StripHtml(job.JobDescription);

                    // A shorter summary keeps the card quiet and easier to scan.
                    var previewDescription = string.IsNullOrWhiteSpace(plainDescription)
                        ? "Open the vacancy to review the full role details and requirements."
                        : TruncateText(plainDescription, 140);

                    <article class="portal-job-card flex h-full flex-col rounded-[2rem] p-6">
                        @* The title area is intentionally simple so the role name remains the main focus. *@
                        <div class="space-y-3">
                            <span class="inline-flex rounded-full bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-brand">
                                Open role
                            </span>
                            <h3 class="font-display text-2xl font-bold leading-tight tracking-tight text-slate-950">@job.JobTitle</h3>
                        </div>

                        @* A single body paragraph with consistent line-height keeps the text rhythm even. *@
                        <p class="mt-5 text-sm leading-7 text-slate-600">@previewDescription</p>

                        @* The metadata row stays compact so the card still feels minimal. *@
                        <div class="mt-6 grid gap-3 sm:grid-cols-3">
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Posted</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@((job.PostedDate ?? DateTime.Today).ToString("MMM dd, yyyy"))</p>
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Deadline</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@((job.ExpiredDate ?? DateTime.Today).ToString("MMM dd, yyyy"))</p>
                            </div>
                            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Positions</p>
                                <p class="mt-2 text-sm font-semibold text-slate-900">@(job.RequiredNumber ?? 1)</p>
                            </div>
                        </div>

                        @* The footer uses one clear action so the next step is obvious. *@
                        <div class="mt-6 border-t border-slate-200 pt-6">
                            @if (appliedJobIds.Contains(job.JobId))
                            {
                                <span class="inline-flex cursor-not-allowed items-center justify-center rounded-2xl bg-emerald-100 px-5 py-3 text-sm font-semibold text-emerald-700">
                                    Applied
                                </span>
                            }
                            else
                            {
                                <a asp-controller="AllJobs"
                                   asp-action="Create"
                                   asp-route-id="@job.JobId"
                                   class="portal-gradient inline-flex items-center justify-center rounded-2xl px-5 py-3 text-sm font-semibold text-white shadow-soft transition duration-300 hover:-translate-y-0.5 hover:shadow-2xl">
                                    Apply now
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            @* The empty state stays concise so it matches the calmer direction of the rest of the page. *@
            <div class="portal-surface rounded-[2rem] px-8 py-14 text-center">
                <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">No active vacancies</p>
                <h3 class="mt-4 font-display text-2xl font-bold tracking-tight text-slate-950">New opportunities will appear here.</h3>
                <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-600">Please check back later for upcoming openings at EBC.</p>
            </div>
        }
    </div>
</section>
